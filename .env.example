# Tacit — environment template. Copy what you need into .env.local.
# Nothing here is secret by default; fill secrets only for devnet OAuth.

# ── Ledger mode ──────────────────────────────────────────────────────────────
# sandbox (default) | canton3-local | devnet
TACIT_LEDGER_MODE=sandbox

# ── sandbox: Daml 2.x sandbox, v1 HTTP JSON API (the offline / DEMO FALLBACK tier)
DAML_JSON_API_URL=http://localhost:7575
DAML_LEDGER_ID=sandbox
DAML_APPLICATION_ID=tacit
DAML_TOKEN_SECRET=tacit-dev-secret
TACIT_PACKAGE_ID=c0f7a95e01d57cc04dd72478d7886b98556d0831956767ac8e84f42b664bde1a

# ── canton3-local + devnet: Canton 3.x, v2 JSON Ledger API ────────────────────
# LocalNet app-provider JSON API is localhost:3975; a devnet validator is
# http://json-ledger-api.localhost
TACIT_V2_API_URL=http://localhost:3975
# none | static | oauth   (devnet defaults to oauth if unset)
TACIT_V2_AUTH=none
TACIT_V2_STATIC_TOKEN=
# The frozen v2 templates package (Daml 3.4.11, verbatim port of the v1 model)
TACIT_PACKAGE_ID_V2=fdfbfcf0030194e0a70899d6f9d0d16eb4989459096ad763128240ae43b14cff

# devnet OAuth2 client-credentials — only when TACIT_V2_AUTH=oauth
TACIT_DEVNET_TOKEN_URL=
TACIT_DEVNET_CLIENT_ID=
TACIT_DEVNET_CLIENT_SECRET=
TACIT_DEVNET_AUDIENCE=
TACIT_DEVNET_SCOPE=

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL for OG/metadata (inlined at BUILD time, so set before `npm run build`)
# Live deployment uses: NEXT_PUBLIC_APP_URL=https://tacit.80-225-209-190.sslip.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional (server-side): loopback runner health URLs for /api/work/health
# TACIT_RUNNER_HEALTH_URLS=http://127.0.0.1:7011,http://127.0.0.1:7012,http://127.0.0.1:7013

# Optional: LLM-backed agent bidding (OpenAI-compatible). No key → deterministic
# fallback (never hangs). See app/lens/agents/llm.ts for the exact variable names.
# GRADIENT_API_KEY=
