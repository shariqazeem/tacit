{
  "name": "tacit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preflight": "node scripts/preflight.mjs",
    "preflight:e2e": "node scripts/preflight-e2e.mjs",
    "daml:build:v1": "cd daml && daml build",
    "daml:build:v2": "cd daml3 && daml build",
    "daml:test:v2": "cd daml3 && daml build && cd ../daml3-test && daml test",
    "daml:build:work": "cd daml3 && daml build && cd ../tacit-work && daml build",
    "daml:test:work": "cd daml3 && daml build && cd ../tacit-work && daml build && cd ../tacit-work-test && daml test",
    "canton3:local": "bash scripts/canton3-local.sh",
    "devnet:bootstrap": "node scripts/devnet-bootstrap.mjs",
    "mcp:build": "npm --prefix mcp install && npm --prefix mcp run build",
    "mcp:start": "node mcp/dist/server.js"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.17",
    "typescript": "^5"
  }
}
