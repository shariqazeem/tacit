{
  "name": "tacit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preflight": "node scripts/preflight.mjs",
    "preflight:e2e": "node scripts/preflight-e2e.mjs",
    "preflight:work": "node scripts/preflight-work-e2e.mjs --require-ledger --require-runners",
    "daml:build:v1": "cd daml && daml build",
    "daml:build:v2": "cd daml3 && daml build",
    "daml:test:v2": "cd daml3 && daml build && cd ../daml3-test && daml test",
    "daml:build:work": "cd daml3 && daml build && cd ../tacit-work && daml build",
    "daml:test:work": "cd daml3 && daml build && cd ../tacit-work && daml build && cd ../tacit-work-test && daml test",
    "daml:build:mandate": "cd tacit-mandate && daml build",
    "daml:test:mandate": "cd tacit-mandate && daml build && cd ../tacit-mandate-test && daml test",
    "canton3:local": "bash scripts/canton3-local.sh",
    "devnet:bootstrap": "node scripts/devnet-bootstrap.mjs",
    "devnet:bootstrap:mandate": "node scripts/devnet-bootstrap-mandate.mjs",
    "mcp:build": "npm --prefix mcp install && npm --prefix mcp run build",
    "mcp:start": "node mcp/dist/server.js",
    "test:work": "node scripts/test-work-unit.mjs",
    "demo:check": "node scripts/demo-check.mjs",
    "test:services": "node scripts/test-services.mjs",
    "test:market": "node scripts/test-market.mjs",
    "test:mandate": "node scripts/test-mandate-unit.mjs",
    "test:ledger-errors": "node scripts/test-ledger-errors.mjs",
    "test:planner": "node scripts/test-planner.mjs",
    "planner:smoke": "node scripts/planner-smoke.mjs",
    "demo:prime": "node scripts/demo-prime.mjs",
    "preflight:agentic": "node scripts/preflight-agentic.mjs --require-ledger --require-runners",
    "preflight:console": "node scripts/preflight-console.mjs --require-ledger --require-runners",
    "preflight:probe": "node scripts/preflight-probe.mjs --require-ledger --require-runners",
    "preflight:market": "node scripts/preflight-market.mjs --require-ledger --require-runners",
    "preflight:mandate": "node scripts/preflight-mandate.mjs --require-ledger",
    "test:agents": "node scripts/test-agents.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.17",
    "typescript": "^5"
  }
}
