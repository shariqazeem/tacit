-- Tacit — proof of ledger-enforced privacy: sealed-bid secrecy, atomic award +
-- payment, and PERMISSIONED AUDIT (an auditor sees settlements but never bids).
--
-- Run with `daml test` (in-memory ledger). `query @T party` returns ONLY the
-- contracts on which `party` is a stakeholder — exactly as the live ledger
-- would — so these assertions test ledger-enforced visibility, not app logic.

module Tacit.Test where

import Daml.Script
import Tacit.Sealed

test : Script ()
test = script do
  buyer     <- allocateParty "Buyer"
  providerA <- allocateParty "ProviderA"
  providerB <- allocateParty "ProviderB"
  providerC <- allocateParty "ProviderC"
  eve       <- allocateParty "Eve" -- unrelated party

  rfs <- submit buyer $ createCmd Rfs with
    rfsId = "RFS-1"
    buyer = buyer
    description = "Market-intelligence report"
    maxBudget = 50.0
    title = "Market-intelligence report"
    category = "research"
    auditor = None

  bidA <- submit providerA $ createCmd SealedBid with rfsId = "RFS-1"; provider = providerA; buyer = buyer; price = 31.0
  bidB <- submit providerB $ createCmd SealedBid with rfsId = "RFS-1"; provider = providerB; buyer = buyer; price = 42.0
  bidC <- submit providerC $ createCmd SealedBid with rfsId = "RFS-1"; provider = providerC; buyer = buyer; price = 28.0

  -- (1-3) Sealed-bid visibility, while bids are active (before the award).
  buyerBids <- query @SealedBid buyer
  aBids <- query @SealedBid providerA
  bBids <- query @SealedBid providerB
  cBids <- query @SealedBid providerC
  eveBids <- query @SealedBid eve
  let priceOf rows = map (\(_, c) -> c.price) rows
  assertMsg "buyer sees all 3 sealed bids"     (length buyerBids == 3)
  assertMsg "provider A sees only its own (31)" (priceOf aBids == [31.0])
  assertMsg "provider B sees only its own (42)" (priceOf bBids == [42.0])
  assertMsg "provider C sees only its own (28)" (priceOf cBids == [28.0])
  assertMsg "unrelated party (Eve) sees none"   (length eveBids == 0)

  iou <- submit buyer $ createCmd Iou with
    issuer = buyer; owner = buyer; amount = 28.0; currency = "USD.demo"

  -- (Negative A) Over-budget award must fail (60 > maxBudget 50). RFS not consumed.
  bidOver <- submit providerA $ createCmd SealedBid with rfsId = "RFS-1"; provider = providerA; buyer = buyer; price = 60.0
  submitMustFail buyer $ exerciseCmd rfs (Award with winningBid = bidOver, losingBids = [], paymentCid = iou)

  -- (Negative B) Payment amount must match the bid.
  submitMustFail buyer $ exerciseCmd rfs (Award with winningBid = bidB, losingBids = [], paymentCid = iou)

  -- (4) Buyer awards the winner (C @ 28) atomically.
  _settle <- submit buyer $ exerciseCmd rfs
    (Award with winningBid = bidC, losingBids = [bidA, bidB, bidOver], paymentCid = iou)

  -- (5,6) Settlement visibility.
  buyerSettle <- query @Settlement buyer
  cSettle <- query @Settlement providerC
  aSettle <- query @Settlement providerA
  bSettle <- query @Settlement providerB
  eveSettle <- query @Settlement eve
  assertMsg "buyer sees the settlement"            (length buyerSettle == 1)
  assertMsg "winning provider C sees settlement"   (length cSettle == 1)
  assertMsg "losing provider A sees NO settlement" (length aSettle == 0)
  assertMsg "losing provider B sees NO settlement" (length bSettle == 0)
  assertMsg "unrelated party sees NO settlement"   (length eveSettle == 0)

  -- (7) Settlement price + recorded payment + on-ledger title/category.
  assertMsg "settlement price == 28" (map (\(_, s) -> s.price) buyerSettle == [28.0])
  assertMsg "settlement records the payment (Some (28, USD.demo))"
    (map (\(_, s) -> s.paid) buyerSettle == [Some (28.0, "USD.demo")])
  assertMsg "settlement carries the on-ledger title + category"
    (map (\(_, s) -> (s.title, s.category)) buyerSettle == [("Market-intelligence report", "research")])

  -- (P2.1) Payment moved to the winner, atomically, and only stakeholders see it.
  cIou <- query @Iou providerC
  buyerIou <- query @Iou buyer
  aIou <- query @Iou providerA
  eveIou <- query @Iou eve
  assertMsg "winner C now owns an IOU of 28"        (map (\(_, i) -> (i.owner, i.amount)) cIou == [(providerC, 28.0)])
  assertMsg "buyer's original IOU archived; sees only the transferred one (owner C)"
    (map (\(_, i) -> i.owner) buyerIou == [providerC])
  assertMsg "losing provider A cannot see the payment IOU" (length aIou == 0)
  assertMsg "unrelated party cannot see the payment IOU"   (length eveIou == 0)

  -- Atomicity: every sealed bid closed and the RFS consumed after award.
  bidsAfter <- query @SealedBid buyer
  rfsAfter  <- query @Rfs buyer
  assertMsg "all sealed bids archived after award" (length bidsAfter == 0)
  assertMsg "RFS consumed after award (no re-award)" (length rfsAfter == 0)

  -- (Negative C) A second award attempt fails — the RFS was consumed.
  submitMustFail buyer $ exerciseCmd rfs (Award with winningBid = bidC, losingBids = [], paymentCid = iou)

  debug "PROVED: sealed-bid privacy + atomic award + atomic payment + on-ledger title."
  pure ()

-- PERMISSIONED AUDIT: an auditor sees requests + settlements (incl. paid) but
-- NEVER a sealed bid (not even the winner's) or any IOU. auditor=None → nothing.
testAuditor : Script ()
testAuditor = script do
  buyer     <- allocateParty "Buyer"
  providerA <- allocateParty "ProviderA"
  providerB <- allocateParty "ProviderB"
  providerC <- allocateParty "ProviderC"
  auditor   <- allocateParty "Auditor"

  -- Deal 1 — WITH an auditor observing.
  rfs1 <- submit buyer $ createCmd Rfs with
    rfsId = "RFS-AUD"
    buyer = buyer
    description = "Competitive analysis of DeFi lending protocols"
    maxBudget = 50.0
    title = "Market-intelligence report"
    category = "research"
    auditor = Some auditor

  a1 <- submit providerA $ createCmd SealedBid with rfsId = "RFS-AUD"; provider = providerA; buyer = buyer; price = 31.0
  b1 <- submit providerB $ createCmd SealedBid with rfsId = "RFS-AUD"; provider = providerB; buyer = buyer; price = 42.0
  c1 <- submit providerC $ createCmd SealedBid with rfsId = "RFS-AUD"; provider = providerC; buyer = buyer; price = 28.0

  -- WHILE bids are active: auditor sees the request but NOT one single bid.
  audRfs <- query @Rfs auditor
  audBidsBefore <- query @SealedBid auditor
  assertMsg "auditor sees the RFS it oversees (title on-ledger)"
    (map (\(_, r) -> r.title) audRfs == ["Market-intelligence report"])
  assertMsg "auditor sees NO sealed bids (not even the winner's)" (length audBidsBefore == 0)

  iou1 <- submit buyer $ createCmd Iou with issuer = buyer; owner = buyer; amount = 28.0; currency = "USD.demo"
  _ <- submit buyer $ exerciseCmd rfs1 (Award with winningBid = c1, losingBids = [a1, b1], paymentCid = iou1)

  -- AFTER award: auditor sees the settlement (winner/price/paid/title) but NOT
  -- the IOU (wealth stays private) and STILL no bid.
  audSettle <- query @Settlement auditor
  audIou <- query @Iou auditor
  audBidsAfter <- query @SealedBid auditor
  assertMsg "auditor sees exactly one settlement" (length audSettle == 1)
  assertMsg "auditor settlement carries winner + price + paid + title"
    (map (\(_, s) -> (s.provider, s.price, s.paid, s.title)) audSettle
      == [(providerC, 28.0, Some (28.0, "USD.demo"), "Market-intelligence report")])
  assertMsg "auditor CANNOT see any sealed bid after award either" (length audBidsAfter == 0)
  assertMsg "auditor CANNOT see the payment IOU (wealth stays private)" (length audIou == 0)

  -- Deal 2 — WITHOUT an auditor (auditor = None): the auditor sees nothing new.
  rfs2 <- submit buyer $ createCmd Rfs with
    rfsId = "RFS-NOAUD"
    buyer = buyer
    description = "A second, unaudited deal"
    maxBudget = 50.0
    title = "Private procurement"
    category = "other"
    auditor = None

  audRfs2 <- query @Rfs auditor -- deal-1 RFS consumed; deal-2 RFS has auditor=None → invisible
  assertMsg "auditor does not see the no-auditor RFS" (length audRfs2 == 0)

  a2 <- submit providerA $ createCmd SealedBid with rfsId = "RFS-NOAUD"; provider = providerA; buyer = buyer; price = 33.0
  c2 <- submit providerC $ createCmd SealedBid with rfsId = "RFS-NOAUD"; provider = providerC; buyer = buyer; price = 27.0
  iou2 <- submit buyer $ createCmd Iou with issuer = buyer; owner = buyer; amount = 27.0; currency = "USD.demo"
  _ <- submit buyer $ exerciseCmd rfs2 (Award with winningBid = c2, losingBids = [a2], paymentCid = iou2)

  audSettleAfter2 <- query @Settlement auditor
  assertMsg "auditor still sees ONLY deal 1's settlement (deal 2 had no auditor)"
    (length audSettleAfter2 == 1)

  debug "PROVED: permissioned audit — auditor sees requests + settlements (incl. paid) but NEVER sealed bids or IOUs; auditor=None -> invisible."
  pure ()
