# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
mcp/node_modules
mcp/dist
runner/node_modules
runner/dist
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/parallax
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# daml build artifacts (DARs are rebuildable via npm run daml:build:v1|v2)
.daml/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# keys / secrets (never commit)
*.key
p2p.key

# logs
/logs/
/log/
*.log

# preview launch config (session-specific paths)
.claude/launch.json

# working strategy doc (not part of the build)
TACIT_FIRST_PLACE_BUILD_STRATEGY_AND_PROMPTS.md
runner/src/_shared.ts
